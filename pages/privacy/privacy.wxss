.page {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.section {
  padding: 22rpx;
  margin-bottom: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  line-height: 1.7;
  color: #374151;
}

.section-title {
  font-weight: 650;
  margin-bottom: 10rpx;
  color: #202124;
}

.primary {
  margin-top: 24rpx;
  background: #4A90D9;
  color: #ffffff;
}
