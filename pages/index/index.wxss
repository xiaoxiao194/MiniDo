.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 220rpx;
  box-sizing: border-box;
}

.header-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
}

.weekly-link {
  color: #4A90D9;
  font-size: 28rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  background: #eef1f5;
  color: #4b5563;
}

.tab.active {
  background: #4A90D9;
  color: #ffffff;
}

.tag-filter,
.recent-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.chip {
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  background: #eef1f5;
  color: #4b5563;
  font-size: 24rpx;
}

.chip.selected {
  background: #4A90D9;
  color: #ffffff;
}

.task-card {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  transition: opacity 160ms ease, transform 160ms ease;
}

.completed-card {
  opacity: 0.68;
}

.check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #9ca3af;
  margin-top: 4rpx;
}

.check.done {
  background: #4A90D9;
  border-color: #4A90D9;
  transform: scale(1.08);
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-weight: 650;
  line-height: 1.4;
}

.task-title.done {
  color: #9ca3af;
  text-decoration: line-through;
}

.pin {
  display: inline-block;
  margin-right: 8rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: #e7f1fb;
  color: #4A90D9;
  font-size: 20rpx;
}

.meta,
.excerpt {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.task-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 22rpx;
}

.tag-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #4A90D9;
  font-size: 22rpx;
}

.fold,
.empty {
  padding: 24rpx;
  text-align: center;
  color: #6b7280;
}

.overdue-fold {
  color: #E03131;
  background: #FFF5F5;
  border-radius: 8rpx;
}

.overdue-text {
  color: #E03131;
}

.today-text {
  color: #F08C00;
}

.empty {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-art {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
}

.quick-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.quick-input {
  flex: 1;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
}

.icon-button,
.add-button {
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.add-button {
  background: #4A90D9;
  color: #ffffff;
}

.advanced {
  margin-top: 16rpx;
}

.detail-input,
.tag-input {
  width: 100%;
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
}

.detail-input {
  height: 120rpx;
}

.image-row {
  display: flex;
  gap: 12rpx;
  margin: 16rpx 0;
}

.image-thumb,
.image-add {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  background: #eef1f5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
}

.image-thumb {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
}

.picker-value {
  color: #4A90D9;
}
