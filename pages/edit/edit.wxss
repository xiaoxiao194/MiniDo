.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.title-input,
.detail-input,
.tag-input {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  margin-bottom: 18rpx;
}

.title-input {
  height: 84rpx;
  font-size: 34rpx;
  font-weight: 650;
}

.detail-input {
  height: 180rpx;
}

.section {
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  margin-bottom: 18rpx;
}

.section-title {
  font-weight: 650;
  margin-bottom: 16rpx;
}

.image-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.image-thumb,
.image-add {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  border-radius: 8rpx;
  background: #eef1f5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
}

.image-thumb.failed {
  background: #fee2e2;
  color: #b91c1c;
}

.remove {
  position: absolute;
  top: 6rpx;
  right: 10rpx;
  font-size: 34rpx;
}

.hint,
.status {
  color: #6b7280;
  font-size: 24rpx;
  margin-top: 14rpx;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 76rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  margin-bottom: 18rpx;
}

.picker-value {
  color: #4A90D9;
}

.tag-color-row {
  padding: 12rpx 0;
}

.tag-preview {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag-dot,
.color-dot {
  display: inline-block;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.color-dot {
  width: 38rpx;
  height: 38rpx;
  border: 3rpx solid transparent;
}

.color-dot.selected {
  border-color: #202124;
}

.primary,
.secondary,
.danger {
  margin-top: 18rpx;
}

.primary {
  background: #4A90D9;
  color: #ffffff;
}

.danger {
  color: #dc2626;
}
